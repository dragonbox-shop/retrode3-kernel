// FIXME: these includes should be consolidated with other Ingenic SoC

#include <dt-bindings/clock/ingenic,tcu.h>
#include <dt-bindings/clock/ingenic,x2000-cgu.h>
#include <dt-bindings/clock/ingenic,sysost.h>
#include <dt-bindings/dma/x2000-dma.h>
#include <dt-bindings/interrupt-controller/x2000-irq.h>

/ {
	#address-cells = <1>;
	#size-cells = <1>;
	compatible = "ingenic,x2000", "ingenic,x2000e";

	aliases {
		i2c0 = &i2c0;
		i2c1 = &i2c1;
		i2c2 = &i2c2;
		uart0 = &uart0;
		uart1 = &uart1;
		uart2 = &uart2;
		uart3 = &uart3;
		serial0 = &uart0;
		serial1 = &uart1;
		serial2 = &uart2;
		serial3 = &uart3;
#if 0
		mac0 = &mac0;
		spi0 = &ssi0;
		spi1 = &ssi1;
		pwm = &pwm;
		can0 = &can0;
		can1 = &can1;
#endif
		mmc0 = &msc2;
		mmc1 = &msc1;
	};

	cpus: cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "ingenic,xburst2-fpu2.1-mxu2.1-smt";
			reg = <0x0>;

			clocks = <&cgu X2000_CLK_CPU>;
			clock-names = "cpu";
		};

		cpu1: cpu@1 {
			device_type = "cpu";
			compatible = "ingenic,xburst2-fpu2.1-mxu2.1-smt";
			reg = <0x1>;
		};
	};

	memory {
		device_type = "memory";
		reg = <0x0 0x08000000>;	/* default to 128 MB of the smallest X2000 */
	};

	cpuintc: interrupt-controller {
		#address-cells = <0>;
		#interrupt-cells = <1>;
		interrupt-controller;
		compatible = "mti,cpu-interrupt-controller";
	};

	intc: interrupt-controller@12300000 {
		compatible = "ingenic,x2000-intc";
		reg = <0x12300000 0x50>;

		interrupt-controller;
		#interrupt-cells = <1>;

		interrupt-parent = <&cpuintc>;
		interrupts = <CORE_INTC_IRQ>;
	};

	exclk: ext {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency  = <24000000>;
	};

	rtclk: rtc {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <32768>;
	};

	clk12m: clk12m {
		compatible = "fixed-clock";
		clock-output-names ="clk12m";
		#clock-cells = <0>;
		clock-frequency  = <12000000>;
	};

	cgu: x2000-cgu@10000000 {
		compatible = "ingenic,x2000-cgu", "simple-mfd";
		reg = <0x10000000 0x100>;
		#address-cells = <1>;
		#size-cells = <1>;
		ranges = <0x0 0x10000000 0x100>;

		#clock-cells = <1>;

		clocks = <&exclk>, <&rtclk>, <&clk12m>;
		clock-names = "ext", "rtc", "clk12m";

		otg_phy: usb-phy@3c {
			compatible = "ingenic,x2000-phy";
			reg = <0x3c 0x10>;

			clocks = <&cgu X2000_CLK_OTGPHY>;
			#phy-cells = <0>;
		};

		mac0_phy_ctrl: mac-phy-ctrl@e4 {
			compatible = "syscon";
			reg = <0xe4 0x4>;
		};

		mac1_phy_ctrl: mac-phy-ctrl@e8 {
			compatible = "syscon";
			reg = <0xe8 0x4>;
		};
	};

	ost64: timer@12000000 {
		compatible = "ingenic,x2000-ost64";
		reg = <0x12000000 0x3c>;

		#clock-cells = <1>;

		clocks = <&cgu X2000_CLK_OST>;
		clock-names = "ost";

		/* 6 MHz for the clocksource */
		assigned-clocks = <&ost64 OST_CLK_GLOBAL_TIMER>;
		assigned-clock-rates = <6000000>;
	};

	ost32: timer@12100000 {
		compatible = "ingenic,x2000-ost32";
		reg = <0x12100000 0x3c>;

		#clock-cells = <1>;

		clocks = <&cgu X2000_CLK_OST>;
		clock-names = "ost";

		interrupt-parent = <&cpuintc>;
		interrupts = <CORE_SYS_OST_IRQ>;

		/* 6 MHz for the system timers */
		assigned-clocks = <&ost32 OST_CLK_EVENT_TIMER0>, <&ost32 OST_CLK_EVENT_TIMER1>;
		assigned-clock-rates = <6000000>, <6000000>;
	};

	tcu: timer@10002000 {
		compatible = "ingenic,x2000-tcu", "ingenic,x1600-tcu", "simple-mfd";
		reg = <0x10002000 0x1000>;
		#address-cells = <1>;
		#size-cells = <1>;
		ranges = <0x0 0x10002000 0x1000>;

		#clock-cells = <1>;

		clocks = <&cgu X2000_CLK_EXCLK>;
		clock-names = "ext";

		interrupt-controller;
		#interrupt-cells = <1>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_TCU0>, <IRQ_TCU1>, <IRQ_TCU2>;

		wdt: watchdog@0 {
			compatible = "ingenic,x2000-watchdog", "ingenic,jz4780-watchdog";
			reg = <0x0 0x10>;

			clocks = <&tcu TCU_CLK_WDT>;
			clock-names = "wdt";
		};
	};

	rtc: rtc@10003000 {
		compatible = "ingenic,x2000-rtc", "ingenic,jz4780-rtc";
		reg = <0x10003000 0x4c>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_RTC>;

		clocks = <&cgu X2000_CLK_RTCLK>;
		clock-names = "rtc";
	};

	pinctrl: pin-controller@10010000 {
		compatible = "ingenic,x2000-pinctrl";
		reg = <0x10010000 0x1000>;
		#address-cells = <1>;
		#size-cells = <0>;

		gpa: gpio@0 {
			compatible = "ingenic,x2000-gpio";
			reg = <0>;

			gpio-controller;
			gpio-ranges = <&pinctrl 0 0 32>;
			#gpio-cells = <2>;

			interrupt-controller;
			#interrupt-cells = <2>;

			interrupt-parent = <&intc>;
			interrupts = <IRQ_GPIO0>;
		};

		gpb: gpio@1 {
			compatible = "ingenic,x2000-gpio";
			reg = <1>;

			gpio-controller;
			gpio-ranges = <&pinctrl 0 32 32>;
			#gpio-cells = <2>;

			interrupt-controller;
			#interrupt-cells = <2>;

			interrupt-parent = <&intc>;
			interrupts = <IRQ_GPIO1>;
		};

		gpc: gpio@2 {
			compatible = "ingenic,x2000-gpio";
			reg = <2>;

			gpio-controller;
			gpio-ranges = <&pinctrl 0 64 32>;
			#gpio-cells = <2>;

			interrupt-controller;
			#interrupt-cells = <2>;

			interrupt-parent = <&intc>;
			interrupts = <IRQ_GPIO2>;
		};

		gpd: gpio@3 {
			compatible = "ingenic,x2000-gpio";
			reg = <3>;

			gpio-controller;
			gpio-ranges = <&pinctrl 0 96 32>;
			#gpio-cells = <2>;

			interrupt-controller;
			#interrupt-cells = <2>;

			interrupt-parent = <&intc>;
			interrupts = <IRQ_GPIO3>;
		};

		gpe: gpio@4 {
			compatible = "ingenic,x2000-gpio";
			reg = <4>;

			gpio-controller;
			gpio-ranges = <&pinctrl 0 128 32>;
			#gpio-cells = <2>;

			interrupt-controller;
			#interrupt-cells = <2>;

			interrupt-parent = <&intc>;
			interrupts = <IRQ_GPIO4>;
		};
	};

	uart0: serial@10030000 {
		compatible = "ingenic,x2000-uart";
		reg = <0x10030000 0x100>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_UART0>;

		clocks = <&exclk>, <&cgu X2000_CLK_UART0>;
		clock-names = "baud", "module";

		status = "disabled";
	};

	uart1: serial@10031000 {
		compatible = "ingenic,x2000-uart";
		reg = <0x10031000 0x100>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_UART1>;

		clocks = <&exclk>, <&cgu X2000_CLK_UART1>;
		clock-names = "baud", "module";

		status = "disabled";
	};

	uart2: serial@10032000 {
		compatible = "ingenic,x2000-uart";
		reg = <0x10032000 0x100>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_UART2>;

		clocks = <&exclk>, <&cgu X2000_CLK_UART2>;
		clock-names = "baud", "module";

		status = "disabled";
	};

	uart3: serial@10033000 {
		compatible = "ingenic,x2000-uart";
		reg = <0x10033000 0x100>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_UART3>;

		clocks = <&exclk>, <&cgu X2000_CLK_UART3>;
		clock-names = "baud", "module";

		status = "disabled";
	};

	uart4: serial@10034000 {
		compatible = "ingenic,x2000-uart";
		reg = <0x10034000 0x100>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_UART4>;

		clocks = <&exclk>, <&cgu X2000_CLK_UART4>;
		clock-names = "baud", "module";

		status = "disabled";
	};

	uart5: serial@10035000 {
		compatible = "ingenic,x2000-uart";
		reg = <0x10035000 0x100>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_UART5>;

		clocks = <&exclk>, <&cgu X2000_CLK_UART5>;
		clock-names = "baud", "module";

		status = "disabled";
	};

	uart6: serial@10036000 {
		compatible = "ingenic,x2000-uart";
		reg = <0x10036000 0x100>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_UART6>;

		clocks = <&exclk>, <&cgu X2000_CLK_UART6>;
		clock-names = "baud", "module";

		status = "disabled";
	};

	uart7: serial@10037000 {
		compatible = "ingenic,x2000-uart";
		reg = <0x10037000 0x100>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_UART7>;

		clocks = <&exclk>, <&cgu X2000_CLK_UART7>;
		clock-names = "baud", "module";

		status = "disabled";
	};

	uart8: serial@10038000 {
		compatible = "ingenic,x2000-uart";
		reg = <0x10038000 0x100>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_UART8>;

		clocks = <&exclk>, <&cgu X2000_CLK_UART8>;
		clock-names = "baud", "module";

		status = "disabled";
	};

	uart9: serial@10039000 {
		compatible = "ingenic,x2000-uart";
		reg = <0x10039000 0x100>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_UART9>;

		clocks = <&exclk>, <&cgu X2000_CLK_UART9>;
		clock-names = "baud", "module";

		status = "disabled";
	};

	i2c0: i2c-controller@10050000 {
		compatible = "ingenic,x2000-i2c", "ingenic,x1000-i2c";
		reg = <0x10050000 0x1000>;
		#address-cells = <1>;
		#size-cells = <0>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_I2C0>;

		clocks = <&cgu X2000_CLK_I2C0>;

		status = "disabled";
	};

	i2c1: i2c-controller@10051000 {
		compatible = "ingenic,x2000-i2c", "ingenic,x1000-i2c";
		reg = <0x10051000 0x1000>;
		#address-cells = <1>;
		#size-cells = <0>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_I2C1>;

		clocks = <&cgu X2000_CLK_I2C1>;

		status = "disabled";
	};

	i2c2: i2c-controller@10052000 {
		compatible = "ingenic,x2000-i2c", "ingenic,x1000-i2c";
		reg = <0x10052000 0x1000>;
		#address-cells = <1>;
		#size-cells = <0>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_I2C2>;

		clocks = <&cgu X2000_CLK_I2C2>;

		status = "disabled";
	};

	i2c3: i2c-controller@10053000 {
		compatible = "ingenic,x2000-i2c", "ingenic,x1000-i2c";
		reg = <0x10053000 0x1000>;
		#address-cells = <1>;
		#size-cells = <0>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_I2C3>;

		clocks = <&cgu X2000_CLK_I2C3>;

		status = "disabled";
	};

	i2c4: i2c-controller@10054000 {
		compatible = "ingenic,x2000-i2c", "ingenic,x1000-i2c";
		reg = <0x10054000 0x1000>;
		#address-cells = <1>;
		#size-cells = <0>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_I2C4>;

		clocks = <&cgu X2000_CLK_I2C4>;

		status = "disabled";
	};

	i2c5: i2c-controller@10055000 {
		compatible = "ingenic,x2000-i2c", "ingenic,x1000-i2c";
		reg = <0x10055000 0x1000>;
		#address-cells = <1>;
		#size-cells = <0>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_I2C5>;

		clocks = <&cgu X2000_CLK_I2C5>;

		status = "disabled";
	};

	ssi0: spi@10043000 {
		compatible = "ingenic,x2000-spi";
		reg = <0x10043000 0x1c>;
		#address-cells = <1>;
		#size-cells = <0>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_SSI0>;

		clocks = <&cgu X2000_CLK_SSI0>;
		clock-names = "spi";

		dmas = <&pdma X2000_DMA_SSI0_RX 0xffffffff>,
			   <&pdma X2000_DMA_SSI0_TX 0xffffffff>;
		dma-names = "rx", "tx";

		status = "disabled";
	};

	ssi1: spi@10044000 {
		compatible = "ingenic,x2000-spi";
		reg = <0x10044000 0x1c>;
		#address-cells = <1>;
		#size-cells = <0>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_SSI1>;

		clocks = <&cgu X2000_CLK_SSI1>;
		clock-names = "spi";

		dmas = <&pdma X2000_DMA_SSI1_RX 0xffffffff>,
			   <&pdma X2000_DMA_SSI1_TX 0xffffffff>;
		dma-names = "rx", "tx";

		status = "disabled";
	};

	sadc: sadc@10070000 {
		compatible = "ingenic,sadc";
		reg = <0x10070000 0x32>;
		interrupt-parent = <&intc>;
		interrupts = <IRQ_SADC>;
		status = "disable";
	};

	dtrng: trng@10072000 {
		compatible = "ingenic,dtrng-x2000", "ingenic,dtrng-x1830";
		reg = <0x10072000 0xc>;

		clocks = <&cgu X2000_CLK_DTRNG>;

		status = "disabled";
	};

	pdma: dma-controller@13420000 {
		compatible = "ingenic,x2000-dma", "ingenic,x1830-dma";
		reg = <0x13420000 0x400>, <0x13421000 0x40>;
		#dma-cells = <2>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_PDMA>;

		clocks = <&cgu X2000_CLK_PDMA>;
	};

	mcu: mcu@13420000 {
		compatible = "ingenic,x2000-mcu";
		reg = <0x13420000 0x10000>;
		interrupt-parent = <&intc>;
		interrupt-names = "pdmam";
		interrupts = <IRQ_PDMAM>;
		ingenic,tcsm_size = <16384>;
	};

	sfc: spi@13440000 {
		compatible = "ingenic,x2000-sfc";
		reg = <0x13440000 0x1000>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_SFC>;

		clocks = <&cgu X2000_CLK_SFC>;
		clock-names = "sfc";

		status = "disabled";
	};

	msc0: sdhci@13450000 {
		compatible = "ingenic,x2000-sdhci";
		reg = <0x13450000 0x10000>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_MSC0>;

		clocks = <&cgu X2000_CLK_MSC_EXCLK>, <&cgu X2000_CLK_MSC0>;
		clock-names = "ext", "sdhci";

		cap-sd-highspeed;
		cap-sdio-irq;

		sd-uhs-sdr12;
		sd-uhs-sdr25;
		sd-uhs-sdr50;
		sd-uhs-sdr104;

		status = "disabled";
	};

	msc1: sdhci@13460000 {
		compatible = "ingenic,x2000-sdhci";
		reg = <0x13460000 0x10000>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_MSC1>;

		clocks = <&cgu X2000_CLK_MSC_EXCLK>, <&cgu X2000_CLK_MSC1>;
		clock-names = "ext", "sdhci";

		cap-sd-highspeed;
		cap-sdio-irq;

		sd-uhs-sdr12;
		sd-uhs-sdr25;
		sd-uhs-sdr50;
		sd-uhs-sdr104;

		status = "disabled";
	};

	msc2: sdhci@13490000 {
		compatible = "ingenic,x2000-sdhci";
		reg = <0x13490000 0x10000>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_MSC2>;

		clocks = <&cgu X2000_CLK_MSC_EXCLK>, <&cgu X2000_CLK_MSC2>;
		clock-names = "ext", "sdhci";

		cap-sd-highspeed;
		cap-sdio-irq;

		sd-uhs-sdr12;
		sd-uhs-sdr25;
		sd-uhs-sdr50;
		sd-uhs-sdr104;

		status = "disabled";
	};

	mac0: mac@134b0000 {
		compatible = "ingenic,x2000-mac", "snps,dwmac";
		reg = <0x134b0000 0x2000>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_GMAC0>;
		interrupt-names = "macirq";

		clocks = <&cgu X2000_CLK_MAC0>;
		clock-names = "stmmaceth";

		mode-reg = <&mac0_phy_ctrl>;

		status = "disabled";

		mdio0: mdio {
			compatible = "snps,dwmac-mdio";
			#address-cells = <1>;
			#size-cells = <0>;

			status = "disabled";
		};
	};

	mac1: mac@134a0000 {
		compatible = "ingenic,x2000-mac", "snps,dwmac";
		reg = <0x134a0000 0x2000>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_GMAC1>;
		interrupt-names = "macirq";

		clocks = <&cgu X2000_CLK_MAC1>;
		clock-names = "stmmaceth";

		mode-reg = <&mac1_phy_ctrl>;

		status = "disabled";

		mdio1: mdio {
			compatible = "snps,dwmac-mdio";
			#address-cells = <1>;
			#size-cells = <0>;

			status = "disabled";
		};
	};

	otg: usb@13500000 {
		compatible = "ingenic,x2000-otg";
		reg = <0x13500000 0x40000>;

		interrupt-parent = <&intc>;
		interrupts = <IRQ_OTG>;

		clocks = <&cgu X2000_CLK_OTG>;
		clock-names = "otg";

		phys = <&otg_phy>;
		phy-names = "usb2-phy";

		g-rx-fifo-size = <768>;
		g-np-tx-fifo-size = <256>;
		g-tx-fifo-size = <256 256 256 256 256 256 256 512>;

		status = "disabled";
	};
};
